# Files and folders that must NOT ship inside the release ZIP.
# Consumed by the release workflow via `rsync --exclude-from`.
# readme.txt is intentionally NOT listed: it feeds the update dialog.

.git
.gitattributes
.gitignore
.distignore
.github
build
*.zip

# OS / editor cruft
.DS_Store
Thumbs.db
.idea
.vscode

# Developer-only docs (kept in the repo, but not part of the plugin)
CLAUDE.md
RELEASING.md

# Dev-only tooling (phpcs / composer): never part of the shipped plugin
composer.json
composer.lock
phpcs.xml.dist
# Anchored to the repo root: this excludes only the dev phpcs/composer vendor
# dir, NOT the bundled lib/plugin-update-checker/vendor (PucReadmeParser,
# Parsedown) which the update checker needs at runtime. An unanchored "vendor"
# would strip that too and cause a fatal "Class PucReadmeParser not found".
/vendor
